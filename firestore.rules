rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    match /user/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /items/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /types/{typeId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
  }
}